{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "quote.harrisboatworks.ca"
        }
      ],
      "destination": "https://www.mercuryrepower.ca/",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "quote.harrisboatworks.ca"
        }
      ],
      "destination": "https://www.mercuryrepower.ca/:path*",
      "statusCode": 301
    },
    { "source": "/locations/peterborough", "destination": "/locations/peterborough-mercury-dealer", "statusCode": 301 },
    { "source": "/locations/rice-lake", "destination": "/locations/rice-lake-mercury-repower", "statusCode": 301 },
    { "source": "/locations/kawartha-lakes", "destination": "/locations/kawartha-lakes-mercury-outboards", "statusCode": 301 },
    { "source": "/locations/cobourg", "destination": "/locations/cobourg-northumberland-mercury", "statusCode": 301 },
    { "source": "/locations/durham-gta", "destination": "/locations/durham-gta-mercury-pickup", "statusCode": 301 },
    { "source": "/locations/gta", "destination": "/locations/durham-gta-mercury-pickup", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/googlebdeec341596163e7.html", "destination": "/googlebdeec341596163e7.html" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/rss.xml", "destination": "/rss.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/llms.txt", "destination": "/llms.txt" },
    { "source": "/catalog.md", "destination": "/catalog.md" },
    { "source": "/motors/:slug.md", "destination": "/motors/:slug.md" },
    { "source": "/case-studies/:slug.md", "destination": "/case-studies/:slug.md" },
    { "source": "/locations/:slug.md", "destination": "/locations/:slug.md" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/repower", "destination": "/repower/index.html" },
    { "source": "/faq", "destination": "/faq/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/:slug", "destination": "/blog/:slug/index.html" },
    { "source": "/agents", "destination": "/agents/index.html" },
    { "source": "/motors/:slug", "destination": "/motors/:slug/index.html" },
    { "source": "/quote/motor-selection", "destination": "/quote/motor-selection/index.html" },
    { "source": "/trade-in-value", "destination": "/trade-in-value/index.html" },
    { "source": "/accessories", "destination": "/accessories/index.html" },
    { "source": "/compare", "destination": "/compare/index.html" },
    { "source": "/promotions", "destination": "/promotions/index.html" },
    { "source": "/finance-calculator", "destination": "/finance-calculator/index.html" },
    { "source": "/financing-application", "destination": "/financing-application/index.html" },
    { "source": "/mercury-repower-faq", "destination": "/mercury-repower-faq/index.html" },
    { "source": "/how-to-repower-a-boat", "destination": "/how-to-repower-a-boat/index.html" },
    { "source": "/mercury-dealer-canada-faq", "destination": "/mercury-dealer-canada-faq/index.html" },
    { "source": "/mercury-dealer-peterborough", "destination": "/mercury-dealer-peterborough/index.html" },
    { "source": "/mercury-dealer-cobourg", "destination": "/mercury-dealer-cobourg/index.html" },
    { "source": "/mercury-dealer-gta", "destination": "/mercury-dealer-gta/index.html" },
    { "source": "/mercury-pro-xs", "destination": "/mercury-pro-xs/index.html" },
    { "source": "/mercury-outboards-ontario", "destination": "/mercury-outboards-ontario/index.html" },
    { "source": "/mercury-pontoon-outboards", "destination": "/mercury-pontoon-outboards/index.html" },
    { "source": "/case-studies", "destination": "/case-studies/index.html" },
    { "source": "/case-studies/:slug", "destination": "/case-studies/:slug/index.html" },
    { "source": "/locations", "destination": "/locations/index.html" },
    { "source": "/locations/:slug", "destination": "/locations/:slug/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/lovable-uploads/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/boat-types/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.md)",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "X-Robots-Tag", "value": "noindex, follow" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=1, stale-while-revalidate=59"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/google-sheets-sync",
      "schedule": "0 6 * * 1"
    }
  ]
}
