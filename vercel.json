{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/googlebdeec341596163e7.html", "destination": "/googlebdeec341596163e7.html" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/rss.xml", "destination": "/rss.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/llms.txt", "destination": "/llms.txt" },
    { "source": "/.well-known/(.*)", "destination": "/.well-known/$1" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/repower", "destination": "/repower/index.html" },
    { "source": "/faq", "destination": "/faq/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/agents", "destination": "/agents/index.html" },
    { "source": "/quote/motor-selection", "destination": "/quote/motor-selection/index.html" },
    { "source": "/((?!api).*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/lovable-uploads/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/boat-types/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=1, stale-while-revalidate=59"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/google-sheets-sync",
      "schedule": "0 6 * * 1"
    }
  ]
}
